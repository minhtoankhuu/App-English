# Sao chép thành .env rồi chỉnh cho môi trường của bạn. KHÔNG commit .env thật.

POSTGRES_USER=examcraft
POSTGRES_PASSWORD=examcraft
POSTGRES_DB=examcraft

SESSION_SECRET=change-me-in-production
DAILY_GENERATION_LIMIT=10

# Mã hóa API key provider AI trước khi lưu DB — tạo giá trị riêng bằng
# `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
# và đổi ngay ở production, không dùng giá trị mẫu này.
AI_CONFIG_ENCRYPTION_KEY=RzeAmI7PNoRVVxdZyyEaHC1Asjbmt2Af7jWpUvhRdug=

# Tài khoản Admin seed lần đầu — đổi ngay ở môi trường thật.
SEED_ADMIN_EMAIL=admin@examcraft.dev
SEED_ADMIN_PASSWORD=ChangeMe123!

# URL trình duyệt gọi tới backend (không phải tên service Docker nội bộ).
VITE_API_BASE_URL=http://localhost:8000
